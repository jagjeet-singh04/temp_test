<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <property name="connection.driver_class">org.h2.Driver</property>

        <property name="connection.url">jdbc:h2:./options_broker_db;DB_CLOSE_DELAY=-1</property>
        
        
        <property name="connection.username">sa</property>
        <property name="connection.password"></property>
        
       
        <property name="dialect">org.hibernate.dialect.H2Dialect</property>
        
        
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        
        
        <property name = "hibernate.id.new_generator_mappings">true</property>
        
        
        
        
        
        
        
        


        <property name="hbm2ddl.auto">update</property>
        <property name="hbm2ddl.archive.autodetection">class</property>
        
        <property name="hibernate.id.sequence_prefix">SEQ_</property>
        <property name="hibernate.id.optimizer.pooled.prefer_lo">true</property>        
        <property name ="hibernate.id.optimizer.pooled.batch_size">20</property>


        <mapping class="com.bnpp.assessment.models.User"/>
        <mapping class="com.bnpp.assessment.models.Wallet"/>
        <mapping class="com.bnpp.assessment.models.Index"/>
<mapping class="com.bnpp.assessment.models.OptionChain"/>
<mapping class="com.bnpp.assessment.models.OptionStrike"/>
<mapping class="com.bnpp.assessment.models.OptionDelta"/>
<mapping class="com.bnpp.assessment.models.Trade"/>
        
    </session-factory>
</hibernate-configuration>